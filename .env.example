# =========================
# API Keys
# =========================
OPENAI_API_KEY=your_openai_api_key
SARVAM_API_KEY=your_sarvam_api_key

# =========================
# Main LLM
# Used by pipeline/llm_factory.py
# LLM_PROVIDER: openai | google | nvidia
# =========================
LLM_PROVIDER=openai
LLM_LARGE_MODEL=gpt-4o-mini
NVIDIA_LARGE_MODEL=meta/llama-3.1-70b-instruct

# =========================
# Optional Alternative Provider Keys
# Only needed if LLM_PROVIDER or SAFETY_LLM_PROVIDER uses that provider.
# =========================
# GOOGLE_API_KEY=your_google_api_key
# NVIDIA_API_KEY=your_nvidia_api_key

# =========================
# Embedding Model
# EMBEDDING_PROVIDER: openai | sentence_transformers
# =========================
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# =========================
# Safety Model
# =========================
SAFETY_LLM_PROVIDER=openai
SAFETY_LLM_MODEL=gpt-4o-mini
SAFETY_LLM_TEMPERATURE=0.0

# =========================
# Chat Safety Toggles
# =========================
CHAT_SAFETY_ENABLED=true
CHAT_SAFETY_FAIL_CLOSED=true
CHAT_SECURITY_BLOCKING_ENABLED=true
CHAT_LOW_INFO_BLOCKING_ENABLED=true
CHAT_SAFETY_MODEL_CLASSIFICATION_ENABLED=true

# =========================
# Retrieval / Qdrant
# =========================
RETRIEVAL_MODE=hybrid
HYBRID_TOP_K=8
BM25_TOP_K=6
BM25_MARKDOWN_DIR=./data/markdowns
BM25_CHUNK_WORDS=260
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=your_qdrant_api_key
# QDRANT_PATH=./db_storage
QDRANT_COLLECTION_NAME=agritech_knowledge
QDRANT_COLLECTION_NAMES=spring_corn_fertilizers_db,maize_production_manual_db,spring_corn_pest_and_diseases_db,spring_corn_pop_db,farmerbook_db
MAIZE_FAQ_COLLECTION_NAME=maize_faq_db
MAIZE_FAQ_TREE_PATH=./data/maize_knowledge_tree.json
QDRANT_LOG_ENABLED=true
QDRANT_LOG_DIR=./logs/qdrant

# =========================
# PostgreSQL / Redis
# =========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=agritech
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:your_password@postgres:5432/agritech
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true
DATABASE_AUTO_CREATE_TABLES=true
REDIS_URL=redis://localhost:6379/0

# =========================
# PageIndex
# =========================
PAGEINDEX_TREE_PATH=./PageIndex/results/b_structure.json
PAGEINDEX_PDF_PATH=./PageIndex/DATA/b.pdf
PAGEINDEX_MAX_NODES=3
PAGEINDEX_LOG_ENABLED=true
PAGEINDEX_LOG_DIR=./logs/pageindex

# =========================
# Sarvam Speech
# =========================
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE_CODE=unknown
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=hi-IN
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_TTS_AUDIO_FORMAT=wav
SARVAM_TTS_PACE=1.0
SARVAM_TTS_TEMPERATURE=0.6

# =========================
# Frontend / Google OAuth / Chat Limit
# =========================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
AUTH_SESSION_SECRET=replace_with_a_long_random_secret
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CHAT_RATE_LIMIT=3
RATE_LIMITING_NUMBER=2
